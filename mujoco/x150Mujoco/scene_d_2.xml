<!-- Domain 2: dark floor, warm side lighting, dark skybox -->
<mujoco model="rx150_domain_2">
  <include file="rx150.xml"/>
  <option timestep="0.002"/>

  <visual>
    <headlight diffuse="0.3 0.3 0.3" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.2 0.15 0.1 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.1 0.1 0.1" rgb2="0.0 0.0 0.0" width="512" height="512"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1="0.2 0.2 0.2" rgb2="0.1 0.1 0.1" width="512" height="512"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="4 4" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light pos="1.0 0.5 1.0" dir="-1 -0.5 -1" directional="true" diffuse="0.8 0.6 0.4" specular="0.2 0.1 0.0"/>
    <geom name="floor" type="plane" size="2 2 0.05" material="floor_mat"/>
    <camera name="front_cam" pos="0.5 -0.5 0.5" xyaxes="1 0 0 0 1 1"/>
  </worldbody>
</mujoco>
