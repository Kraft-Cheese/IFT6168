<!-- Domain 1: light floor, bright overhead lighting, blue skybox -->
<mujoco model="rx150_domain_1">
  <include file="rx150.xml"/>
  <option timestep="0.002"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0.0 0.0 0.0" width="512" height="512"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.5 0.5 0.5" width="512" height="512"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="4 4" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true" diffuse="0.9 0.9 0.9" specular="0.1 0.1 0.1"/>
    <geom name="floor" type="plane" size="2 2 0.05" material="floor_mat"/>
    <camera name="front_cam" pos="0.5 -0.5 0.5" xyaxes="1 0 0 0 1 1"/>
  </worldbody>
</mujoco>
