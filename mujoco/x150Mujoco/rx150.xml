    <position name="waist_act"        joint="waist"        kp="60"  kv="5"  forcerange="-8 8"   ctrlrange="-3.14158 3.14158"/>
    <position name="shoulder_act"     joint="shoulder"     kp="133" kv="8"  forcerange="-18 18" ctrlrange="-1.85005 1.74533"/>
    <position name="elbow_act"        joint="elbow"        kp="96"  kv="6"  forcerange="-13 13" ctrlrange="-1.78024 1.65806"/>
    <position name="wrist_angle_act"  joint="wrist_angle"  kp="71"  kv="4"  forcerange="-5 5"   ctrlrange="-1.74533 2.14675"/>
    <position name="wrist_rotate_act" joint="wrist_rotate" kp="7"   kv="2"  forcerange="-1 1"   ctrlrange="-3.14158 3.14158"/>
    <position name="left_finger_act"  joint="left_finger"  kp="12"  kv="2"  forcerange="-5 5"   ctrlrange="0.015 0.037"/>
    <position name="right_finger_act" joint="right_finger" kp="12"  kv="2"  forcerange="-5 5"   ctrlrange="-0.037 -0.015"/>
