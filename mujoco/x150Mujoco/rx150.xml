              <!-- End-effector site at gripper tip, mirroring wxai ee_site pattern -->
              <site name="ee_site" pos="0.1 0 0" size="0.001"/>
              <body name="rx150/left_finger_link" pos="0.066 0 0">
                <inertial pos="0.013816 0 0" quat="0.705384 0.705384 -0.0493271 -0.0493271" mass="0.016246" diaginertia="4.79509e-06 3.7467e-06 1.48651e-06"/>
