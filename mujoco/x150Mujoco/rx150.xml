        <joint name="shoulder" pos="0 0 0" axis="0 1 0" range="-1.85005 1.74533" actuatorfrcrange="-18 18" frictionloss="0.1"/>
        <geom quat="0.707107 0 0 0.707107" type="mesh" mesh="rx150_3_upper_arm"/>
        <body name="rx150/forearm_link" pos="0.05 0 0.15">
          <inertial pos="0.08509 0.000404824 0" quat="0.500832 0.499167 -0.500832 0.499167" mass="0.23568" diaginertia="0.0004895 0.000469305 6.24155e-05"/>
