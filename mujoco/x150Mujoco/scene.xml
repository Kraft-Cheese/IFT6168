<!--Scene for x150 robot-->
<mujoco>
  <compiler angle="radian"/>
  <option timestep="0.002"/>
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1="0.8 0.8 0.8"   rgb2="0.5 0.5 0.5" width="512" height="512"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="4 4"/>
  </asset>
  <worldbody>
      <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
      <geom name="floor" type="plane" size="2 2 0.1" material="floor_mat"/>
      <camera name="front_cam" pos="0.5 -0.5 0.5" xyaxes="1 0 0 0 1 1"/>
      <include file="rx150.xml"/>
    </worldbody>
</mujoco>