<!-- Train 8: dark/night skybox (only skybox change from train_7) -->
<mujoco model="rx150_train_8">
  <include file="rx150.xml"/>
  <option timestep="0.002"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.05 0.05 0.05 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.05 0.05 0.1" rgb2="0.0 0.0 0.0" width="512" height="512"/>
    <texture name="floor_tex" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6" width="512" height="512"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="4 4" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1"/>
    <geom name="floor" type="plane" size="2 2 0.05" material="floor_mat"/>
    <camera name="front_cam" pos="0.5 -0.5 0.5" xyaxes="1 0 0 0 1 1"/>
    <body name="target" pos="0.2 0.0 0.2">
      <geom type="sphere" size="0.02" rgba="1 0 0 1" contype="0" conaffinity="0"/>
      <site name="target_site" pos="0 0 0" size="0.001"/>
    </body>
  </worldbody>
</mujoco>
